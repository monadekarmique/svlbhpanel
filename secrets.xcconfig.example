// secrets.xcconfig.example
//
// Copier ce fichier en `secrets.xcconfig` (la version réelle est gitignored
// via .gitignore:41) et remplir les valeurs avec les vrais secrets.
//
//     cp secrets.xcconfig.example secrets.xcconfig
//     vi secrets.xcconfig
//
// ⚠️ Ne JAMAIS committer `secrets.xcconfig`. Si ça arrive : rotate la clé
// immédiatement côté console Anthropic puis `git rm --cached secrets.xcconfig`
// et force-push (avec accord du propriétaire du repo).

// Anthropic Managed Agents — Phase 0
ANTHROPIC_API_KEY = sk-ant-api03-REPLACE_ME

// Agent IDs (remplis par `Scripts/sync_agents.swift` → .lockfile.json, puis
// copiés manuellement ici. Ne pas les hardcoder dans le code Swift.)
ANTHROPIC_AGENT_HDOM_SESSION = agent_01REPLACE_ME
ANTHROPIC_AGENT_PASSEPORT_RATIO = agent_01REPLACE_ME
ANTHROPIC_AGENT_WHATSAPP_VLBH = agent_01REPLACE_ME
